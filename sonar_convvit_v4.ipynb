    "        'Eval'         : CACHE_EVAL,\n",
    "        'Jamming'      : CACHE_JAMMING,\n",
    "    }\n",
    "    print('\\nCache status:')\n",
    "    for label, path in files.items():\n",
    "        if path.exists():\n",
    "            print(f'  ✅ {label:15s} → {path.name} ({path.stat().st_size/1e6:.1f} MB)')\n",
    "        else:\n",
    "            print(f'  🔄 {label:15s} → not found — will compute')\n",
    "\n",
    "cache_status()"
   ]
